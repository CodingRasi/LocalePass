{
  "name": "localepass",
  "version": "1.0.1",
  "description": "Catch localization, visual regressions, and UI breakage before release.",
  "type": "module",
  "license": "MIT",
  "author": "Fisy",
  "homepage": "https://github.com/CodingRasi/LocalePass",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CodingRasi/LocalePass.git"
  },
  "bugs": {
    "url": "https://github.com/CodingRasi/LocalePass/issues"
  },
  "keywords": [
    "localization",
    "i18n",
    "l10n",
    "qa",
    "visual-regression",
    "playwright",
    "github-action",
    "cli"
  ],
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "action.yml",
    "README.md",
    "LICENSE",
    "localepass.schema.json",
    "scripts/postinstall.mjs"
  ],
  "bin": {
    "localepass": "dist/packages/cli/src/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"import('node:fs/promises').then(fs=>fs.rm('dist',{recursive:true,force:true}))\"",
    "dev": "tsx packages/cli/src/index.ts",
    "scan": "tsx packages/cli/src/index.ts scan",
    "lint": "tsc -p tsconfig.json --noEmit",
    "prepack": "npm run clean && npm run build",
    "test:smoke": "node dist/packages/cli/src/index.js --help",
    "test:demo:update-snapshots": "node dist/packages/cli/src/index.js scan --config examples/demo.localepass.config.json --update-snapshots --no-fail-on-issues --terminal-report --open-report",
    "test:demo": "node dist/packages/cli/src/index.js scan --config examples/demo.localepass.config.json --no-fail-on-issues --terminal-report --open-report",
    "test:demo:quick:update-snapshots": "node dist/packages/cli/src/index.js scan --config examples/demo.quick.localepass.config.json --update-snapshots --no-fail-on-issues --terminal-report --open-report",
    "test:demo:quick": "node dist/packages/cli/src/index.js scan --config examples/demo.quick.localepass.config.json --no-fail-on-issues --terminal-report --open-report",
    "postinstall": "node scripts/postinstall.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "playwright": "^1.53.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
